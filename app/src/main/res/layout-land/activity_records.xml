<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    tools:context=".RecordsActivity">


    <TextView android:id="@+id/quizRecordsTitle"
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:textSize="32dp"
        android:textStyle="bold"
        android:text="@string/asl_quiz_records"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0"
        tools:ignore="SpUsage" />


    <TextView android:id="@+id/quizRecordsDesc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textSize="16sp"
        android:text="@string/records_page_desc"
        app:layout_constraintTop_toBottomOf="@id/quizRecordsTitle"
        app:layout_constraintStart_toStartOf="@id/quizRecordsTitle"
        app:layout_constraintEnd_toEndOf="@id/quizRecordsTitle" />


    <!-- HEADINGS -->
    <!-- Sorry I didn't do this in a fragment. I'm sick of fragments -->

    <View android:id="@+id/headingsSection"
        android:layout_width="0dp"
        android:layout_height="30dp"
        app:layout_constraintTop_toTopOf="@id/quizRecordsTitle"
        app:layout_constraintStart_toStartOf="@id/recordsList"
        app:layout_constraintEnd_toEndOf="@id/recordsList"/>

    <TextView android:id="@+id/quizNameRowLabel"
        android:layout_width="90dp"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:layout_margin="4dp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:text="@string/quiz_title"
        app:layout_constraintLeft_toLeftOf="@id/headingsSection"
        app:layout_constraintRight_toRightOf="@id/headingsSection"
        app:layout_constraintTop_toTopOf="@id/headingsSection"
        app:layout_constraintBottom_toBottomOf="@id/headingsSection"
        app:layout_constraintVertical_bias="0.5"
        app:layout_constraintHorizontal_bias="0"/>

    <View android:id="@+id/separator1"
        android:layout_width="2dp"
        android:layout_height="0dp"
        android:background="@color/light_gray"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        app:layout_constraintLeft_toRightOf="@id/quizNameRowLabel"
        app:layout_constraintTop_toTopOf="@id/headingsSection"
        app:layout_constraintBottom_toBottomOf="@id/headingsSection"
        app:layout_constraintVertical_bias="0.5"/>

    <TextView android:id="@+id/attemptRowLabel"
        android:layout_width="70dp"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:layout_margin="4dp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:text="@string/attempt"
        app:layout_constraintStart_toEndOf="@id/separator1"
        app:layout_constraintTop_toTopOf="@id/headingsSection"
        app:layout_constraintBottom_toBottomOf="@id/headingsSection"
        app:layout_constraintVertical_bias="0.5"
        app:layout_constraintHorizontal_bias="0"/>

    <View android:id="@+id/separator2"
        android:layout_width="2dp"
        android:layout_height="0dp"
        android:background="@color/light_gray"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        app:layout_constraintLeft_toRightOf="@id/attemptRowLabel"
        app:layout_constraintTop_toTopOf="@id/headingsSection"
        app:layout_constraintBottom_toBottomOf="@id/headingsSection"
        app:layout_constraintVertical_bias="0.5"/>

    <TextView android:id="@+id/scoreRowLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:layout_margin="4dp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:text="@string/score"
        app:layout_constraintStart_toEndOf="@id/separator2"
        app:layout_constraintEnd_toStartOf="@id/separator3"
        app:layout_constraintTop_toTopOf="@id/headingsSection"
        app:layout_constraintBottom_toBottomOf="@id/headingsSection"
        app:layout_constraintVertical_bias="0.5"
        app:layout_constraintHorizontal_bias=".5"/>

    <View android:id="@+id/separator3"
        android:layout_width="2dp"
        android:layout_height="0dp"
        android:background="@color/light_gray"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        app:layout_constraintRight_toLeftOf="@id/timestampRowLabel"
        app:layout_constraintTop_toTopOf="@id/headingsSection"
        app:layout_constraintBottom_toBottomOf="@id/headingsSection"
        app:layout_constraintVertical_bias="0.5"/>

    <TextView android:id="@+id/timestampRowLabel"
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:layout_margin="4dp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:text="@string/timestamp"
        app:layout_constraintLeft_toLeftOf="@id/headingsSection"
        app:layout_constraintRight_toRightOf="@id/headingsSection"
        app:layout_constraintTop_toTopOf="@id/headingsSection"
        app:layout_constraintBottom_toBottomOf="@id/headingsSection"
        app:layout_constraintVertical_bias="0.5"
        app:layout_constraintHorizontal_bias="1"/>

    <View
        android:layout_width="0dp"
        android:layout_height="2dp"
        android:layout_marginTop="2dp"
        android:background="@color/light_gray"
        app:layout_constraintTop_toBottomOf="@id/headingsSection"
        app:layout_constraintStart_toStartOf="@id/recordsList"
        app:layout_constraintEnd_toEndOf="@id/recordsList"/>

    <!-- END OF HEADINGS -->


    <ListView android:id="@+id/recordsList"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintLeft_toRightOf="@id/quizRecordsTitle"
        app:layout_constraintTop_toBottomOf="@id/headingsSection"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0" />


    <Button android:id="@+id/deleteAllButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:textSize="22sp"
        android:text="@string/delete_all_records"
        app:layout_constraintEnd_toStartOf="@id/recordsList"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="@id/recordsHomeButton"
        app:layout_constraintBottom_toTopOf="@id/recordsHomeButton" />

    <Button android:id="@+id/recordsHomeButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:textSize="22sp"
        android:text="@string/return_to_home_screen"
        app:layout_constraintEnd_toStartOf="@id/recordsList"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/quizRecordsDesc"
        app:layout_constraintVertical_bias=".75"/>

</androidx.constraintlayout.widget.ConstraintLayout>