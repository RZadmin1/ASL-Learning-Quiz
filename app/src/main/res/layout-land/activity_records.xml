<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    tools:context=".RecordsActivity">


    <TextView android:id="@+id/quizRecordsTitle"
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:textSize="32dp"
        android:textStyle="bold"
        android:text="@string/asl_quiz_records"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0"
        tools:ignore="SpUsage" />


    <TextView android:id="@+id/quizRecordsDesc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textSize="16sp"
        android:text="@string/records_page_desc"
        app:layout_constraintTop_toBottomOf="@id/quizRecordsTitle"
        app:layout_constraintStart_toStartOf="@id/quizRecordsTitle"
        app:layout_constraintEnd_toEndOf="@id/quizRecordsTitle" />


    <ListView android:id="@+id/recordsList"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintLeft_toRightOf="@id/quizRecordsTitle"
        app:layout_constraintTop_toTopOf="@id/quizRecordsTitle"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0" />


    <Button android:id="@+id/deleteAllButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:textSize="22sp"
        android:text="@string/delete_all_records"
        app:layout_constraintEnd_toStartOf="@id/recordsList"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="@id/recordsHomeButton"
        app:layout_constraintBottom_toTopOf="@id/recordsHomeButton" />

    <Button android:id="@+id/recordsHomeButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:textSize="22sp"
        android:text="@string/return_to_home_screen"
        app:layout_constraintEnd_toStartOf="@id/recordsList"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/quizRecordsDesc"
        app:layout_constraintVertical_bias=".75"/>

</androidx.constraintlayout.widget.ConstraintLayout>