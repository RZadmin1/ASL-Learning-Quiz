<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <TextView android:id="@+id/quizTypeRowLabel"
        android:layout_width="70dp"
        android:layout_height="24sp"
        android:textSize="14sp"
        android:layout_margin="4dp"
        android:textAlignment="center"
        android:text="Lesson 1"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_bias="0"/>

    <View android:id="@+id/separator1"
        android:layout_width="2dp"
        android:layout_height="match_parent"
        android:background="@color/light_gray"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp"
        app:layout_constraintLeft_toRightOf="@id/quizTypeRowLabel"
        app:layout_constraintRight_toLeftOf="@id/attemptRowLabel"/>

    <TextView android:id="@+id/attemptRowLabel"
        android:layout_width="90dp"
        android:layout_height="24sp"
        android:textSize="14sp"
        android:layout_margin="4dp"
        android:textAlignment="center"
        android:text="Attempt 1"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_bias=".27"/>

    <View android:id="@+id/separator2"
        android:layout_width="2dp"
        android:layout_height="match_parent"
        android:background="@color/light_gray"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp"
        app:layout_constraintLeft_toRightOf="@id/attemptRowLabel"
        app:layout_constraintRight_toLeftOf="@id/scoreRowLabel"/>

    <TextView android:id="@+id/scoreRowLabel"
        android:layout_width="70dp"
        android:layout_height="24sp"
        android:textSize="14sp"
        android:layout_margin="4dp"
        android:textAlignment="center"
        android:textStyle="bold"
        android:text="10/10"
        app:layout_constraintLeft_toRightOf="@+id/attemptRowLabel"
        app:layout_constraintRight_toLeftOf="@+id/dateRowLabel"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_bias=".5"/>

    <View android:id="@+id/separator3"
        android:layout_width="2dp"
        android:layout_height="match_parent"
        android:background="@color/light_gray"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp"
        app:layout_constraintLeft_toRightOf="@id/scoreRowLabel"
        app:layout_constraintRight_toLeftOf="@id/dateRowLabel"/>

    <TextView android:id="@+id/dateRowLabel"
        android:layout_width="60dp"
        android:layout_height="24sp"
        android:textSize="14sp"
        android:layout_margin="4dp"
        android:textAlignment="center"
        android:text="Date"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_bias=".8"/>

    <View android:id="@+id/separator4"
        android:layout_width="2dp"
        android:layout_height="match_parent"
        android:background="@color/light_gray"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp"
        app:layout_constraintLeft_toRightOf="@id/dateRowLabel"
        app:layout_constraintRight_toLeftOf="@id/timeRowLabel"/>

    <TextView android:id="@+id/timeRowLabel"
        android:layout_width="60dp"
        android:layout_height="24sp"
        android:textSize="14sp"
        android:layout_margin="4dp"
        android:textAlignment="center"
        android:text="Time"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_bias="1"/>

</androidx.constraintlayout.widget.ConstraintLayout>