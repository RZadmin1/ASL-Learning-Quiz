<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <TextView android:id="@+id/quizNameRowLabel"
        android:layout_width="90dp"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_margin="4dp"
        android:text="ASL Basics: Lesson 1 Quiz"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintHorizontal_bias="0"/>

    <View android:id="@+id/separator1"
        android:layout_width="2dp"
        android:layout_height="match_parent"
        android:background="@color/light_gray"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        app:layout_constraintLeft_toRightOf="@id/quizNameRowLabel"/>

    <TextView android:id="@+id/attemptRowLabel"
        android:layout_width="70dp"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:layout_margin="4dp"
        android:textAlignment="center"
        android:text="Attempt"
        app:layout_constraintStart_toEndOf="@id/separator1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintHorizontal_bias="0"/>

    <View android:id="@+id/separator2"
        android:layout_width="2dp"
        android:layout_height="match_parent"
        android:background="@color/light_gray"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        app:layout_constraintLeft_toRightOf="@id/attemptRowLabel"/>

    <TextView android:id="@+id/scoreRowLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:layout_margin="4dp"
        android:textAlignment="center"
        android:text="10/10"
        app:layout_constraintStart_toEndOf="@id/separator2"
        app:layout_constraintEnd_toStartOf="@id/separator3"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintHorizontal_bias=".5"/>

    <View android:id="@+id/separator3"
        android:layout_width="2dp"
        android:layout_height="match_parent"
        android:background="@color/light_gray"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        app:layout_constraintRight_toLeftOf="@id/timestampRowLabel"/>

    <TextView android:id="@+id/timestampRowLabel"
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:layout_margin="4dp"
        android:textAlignment="center"
        android:text="MM/DD/YYYY 12:45 PM"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintHorizontal_bias="1"/>


</androidx.constraintlayout.widget.ConstraintLayout>